<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock
                name="header.panel.block"
        >
            <block class="Magento\Directory\Block\Currency"
                   name="currency"
                   before="store_language"
                   template="Magento_Directory::currency.phtml"
            >
                <arguments>
                    <argument name="vite_resolver" xsi:type="object">
                        MageObsidian\ModernFrontend\ViewModel\ViteResolver
                    </argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
