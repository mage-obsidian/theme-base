<?php

use MageObsidian\ModernFrontend\Model\Config\ConfigProvider;
use MageObsidian\ModernFrontend\Block\Template;

/** @var Template $block */
/** @var ConfigProvider $configViewModel */
$configViewModel = $block->getConfigProvider();
?>

<?= $block->getBlockHtml('critical_css_block'); ?>
<?php $i18nDictionaryUrl = $block->getI18nRuntimeConfig()['dictionaryUrl'] ?? ''; ?>
<?php if ($i18nDictionaryUrl): ?>
    <?php // Starts the i18n dictionary fetch during head parse, off the island bootstrap's import chain. ?>
    <link rel="preload" as="fetch" href="<?= $block->escapeUrl($i18nDictionaryUrl) ?>" crossorigin="anonymous"/>
<?php endif; ?>
    <script type="importmap">
        {
            "imports": {
                "vue": "<?= $block->getViewLibFileUrl('vue') ?>",
                "mainStore": "<?= $block->resolvePathByName('js/store/main.js') ?>",
                "@vueuse/core": "<?= $block->getViewLibFileUrl('@vueuse/core') ?>",
                "mini-vueuse": "<?= $block->resolvePathByName('js/lib/mini-vueuse') ?>"
        }
    }
    </script>
<?php
if ($configViewModel->isHmrEnabled()): ?>
    <script type="module" src="/@vite/client"></script>
<?php else:
    $styleHref = $block->escapeUrl($block->getViewFileUrl($configViewModel->getViteGeneratedPath() . '/css/style.css'));
    $criticalCss = $block->getCriticalCss();
    // Defer the sheet only when critical was inlined this request; pages with no
    // critical keep it render-blocking so there is never a FOUC.
    if ($criticalCss && $criticalCss->hasCriticalCss()): ?>
        <link rel="preload" as="style" href="<?= $styleHref ?>" onload="this.onload=null;this.rel='stylesheet'"/>
        <noscript><link rel="stylesheet" href="<?= $styleHref ?>"/></noscript>
    <?php else: ?>
        <link href="<?= $styleHref ?>" rel="stylesheet"/>
    <?php endif; ?>
<?php endif; ?>

<?= $block->getChildHtmlWithExclusions(excludedBlocks: ['critical_css_block']); ?>