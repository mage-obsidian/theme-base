<?xml version="1.0"?>
<!--
  Media image configuration for the whole MageObsidian theme chain.

  The theme chain (theme-base -> default) declares no Luma/blank parent, so it
  inherits NO media image ids. Without these, every catalog surface
  (Block\Product\AbstractProduct::getImage) falls back to the (empty) placeholder.
  This file is the foundational set: the canonical Magento media ids + types so
  listings, PDP, cart, wishlist, swatches and widgets all resolve. Dimensions for
  the catalog grid are bumped (480x600, 4:5) for retina sharpness in our large
  product cards; the rest follow Magento's stock sizes and are refined per surface
  as each migration wave lands.
-->
<view xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:Config/etc/view.xsd">
    <media>
        <images module="Magento_Catalog">
            <image id="bundled_product_customization_page" type="thumbnail">
                <width>140</width>
                <height>140</height>
            </image>
            <image id="cart_cross_sell_products" type="small_image">
                <width>200</width>
                <height>248</height>
            </image>
            <image id="cart_page_product_thumbnail" type="small_image">
                <width>110</width>
                <height>160</height>
            </image>
            <image id="category_page_grid" type="small_image">
                <width>480</width>
                <height>600</height>
            </image>
            <image id="category_page_list" type="small_image">
                <width>480</width>
